DB_PORT=5432 #always 5432 for postgres
DB_NAME=database1name #the name of the database you want to replicate from
DB_USER=database1user #the username for the source database
DB_PASSWORD=database1password #the password for the source database

TARGET_DB_PORT=5432 #always 5432 for postgres
TARGET_DB_NAME=database2name #the name of the database you want to replicate to (it will be created if it doesn't exist)
TARGET_DB_USER=database2user #the username for the target database (it will be created if it doesn't exist)
TARGET_DB_PASSWORD=database2password #the password for the target database (it will be created if it doesn't exist)

EMAIL_USER=your@email.com # email of the sender of the notifications (you need an APP password for this account)
EMAIL_PASS="your app password" # your APP password, not your regular password. example: kstm lccr qwst lkrt
EMAIL_RECEIVER=receiver@email.com # email of the receiver of the notifications
SMTP_SERVER=smtp.gmail.com # or smtp-mail.outlook.com for Outlook
SMTP_PORT=587 # 465 if using SSL, 587 if using TLS

API_KEY=your_api_key_here #replace with your actual API key for authentication (sha256 or sha512 hash of a random string)